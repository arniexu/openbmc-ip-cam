MACHINE ??= "evb-rpi5-64"
DISTRO ?= "openbmc-phosphor"
PACKAGE_CLASSES ?= "package_ipk"
SANITY_TESTED_DISTROS:append ?= " *"
EXTRA_IMAGE_FEATURES ?= "allow-root-login"
USER_CLASSES ?= "buildstats"
PATCHRESOLVE = "noop"
BB_DISKMON_DIRS ??= "\
    STOPTASKS,${TMPDIR},1G,100K \
    STOPTASKS,${DL_DIR},1G,100K \
    STOPTASKS,${SSTATE_DIR},1G,100K \
    STOPTASKS,/tmp,100M,100K \
    HALT,${TMPDIR},100M,1K \
    HALT,${DL_DIR},100M,1K \
    HALT,${SSTATE_DIR},100M,1K \
    HALT,/tmp,10M,1K"
CONF_VERSION = "2"
BB_NO_NETWORK = "0"
LICENSE_FLAGS_ACCEPTED += "synaptics-killswitch"

# Shared cache settings for team builds.
# Update this path to your shared NFS/SMB cache mount.
YOCTO_SHARED_CACHE ?= "/mnt/yocto-cache"
DL_DIR ?= "${YOCTO_SHARED_CACHE}/downloads"
SSTATE_DIR ?= "${YOCTO_SHARED_CACHE}/sstate-cache"

# Use shared mirrors first to reduce duplicate downloads and rebuilds.
INHERIT += "own-mirrors"
SOURCE_MIRROR_URL ?= "file://${YOCTO_SHARED_CACHE}/downloads"
SSTATE_MIRRORS ?= "file://.* file://${YOCTO_SHARED_CACHE}/sstate-cache/PATH"

# Set the root password to '0penBmc'
# Defaults from meta-phosphor/conf/distro/include/phosphor-defaults.inc

OBMC_IMAGE_INCLUDE = "mmc"
require conf/machine/include/obmc-bsp-common.inc
require conf/machine/include/obmc-evb-common.inc

# Generate only SD/MMC artifacts for Raspberry Pi.
IMAGE_FSTYPES = "wic.xz mmc-ext4-tar"

# RPi SD image layout uses boot/root labels; do not enable phosphor-mmc initramfs path.
DISTRO_FEATURES:remove = "phosphor-mmc"
DISTROOVERRIDES:remove = "df-phosphor-mmc"
RDEPENDS:packagegroup-obmc-apps-software:remove = "phosphor-software-manager-updater-mmc"

CONNECTIVITY_CHECK_URIS = "https://www.baidu.com/"

# Build kernel as Image; use explicit linux.bin for firmware kernel loading
KERNEL_IMAGETYPE = "Image"
RPI_USE_U_BOOT = "0"
RPI_EXTRA_IMAGE_BOOT_FILES = "linux.bin"

# RPi5 debug output on both HDMI and UART (GPIO14/15)
ENABLE_UART = "1"
SERIAL_CONSOLES = "115200;ttyAMA0"
RPI_EXTRA_CONFIG:append = "\ndtoverlay=uart0-pi5\n"
RPI_EXTRA_CONFIG:append = "\ndtoverlay=vc4-kms-v3d-pi5\n"
RPI_EXTRA_CONFIG:append = "\nhdmi_drive=2\n"
RPI_EXTRA_CONFIG:append = "\nuart_2ndstage=1\n"
RPI_EXTRA_CONFIG:append = "\nsha256=1\n"
RPI_EXTRA_CONFIG:append = "\nkernel=linux.bin\n"

# Force kernel boot logs to local display and serial console
CMDLINE_SERIAL = "console=ttyAMA0,115200 console=tty1 earlycon loglevel=8 consoleblank=0 vt.global_cursor_default=1 systemd.getty_auto=yes"

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OpenBMC EVB <openbmc-evb@local>
Date: Sun, 19 Apr 2026 10:00:00 +0000
Subject: [PATCH] arm64: dts: rockchip: add rk3568-ok3568-c

Add a first-stage OK3568-C board DTS on top of the existing
rk3568-evb1-ddr4-v10-linux baseline to provide a board-specific DTB
entry for OpenBMC bring-up.

Signed-off-by: OpenBMC EVB <openbmc-evb@local>
---
 arch/arm64/boot/dts/rockchip/Makefile          | 1 +
 arch/arm64/boot/dts/rockchip/rk3568-ok3568-c.dts | 9 +++++++++
 2 files changed, 10 insertions(+)
 create mode 100644 arch/arm64/boot/dts/rockchip/rk3568-ok3568-c.dts

diff --git a/arch/arm64/boot/dts/rockchip/Makefile b/arch/arm64/boot/dts/rockchip/Makefile
index 111111111111..222222222222 100644
--- a/arch/arm64/boot/dts/rockchip/Makefile
+++ b/arch/arm64/boot/dts/rockchip/Makefile
@@ -1,2 +1,3 @@
 dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3566-evb2-lp4x-v10-linux.dtb
 dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3568-evb1-ddr4-v10-linux.dtb
+dtb-$(CONFIG_ARCH_ROCKCHIP) += rk3568-ok3568-c.dtb
 
diff --git a/arch/arm64/boot/dts/rockchip/rk3568-ok3568-c.dts b/arch/arm64/boot/dts/rockchip/rk3568-ok3568-c.dts
new file mode 100644
index 000000000000..333333333333
--- /dev/null
+++ b/arch/arm64/boot/dts/rockchip/rk3568-ok3568-c.dts
@@ -0,0 +1,9 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/dts-v1/;
+
+#include "rk3568-evb1-ddr4-v10-linux.dts"
+
+/ {
+	model = "Forlinx OK3568-C Development Board";
+	compatible = "forlinx,ok3568-c", "rockchip,rk3568";
+};
-- 
2.34.1
